FROM ubuntu:24.04

# Install eBPF toolchain
RUN apt-get update && apt-get install -y \
    # eBPF compilation
    clang-18 \
    llvm-18 \
    libbpf-dev \
    linux-headers-generic \
    # Build tools
    git \
    make \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Install Go 1.23
RUN wget -q https://go.dev/dl/go1.23.4.linux-arm64.tar.gz && \
    tar -C /usr/local -xzf go1.23.4.linux-arm64.tar.gz && \
    rm go1.23.4.linux-arm64.tar.gz

# Add Go and LLVM to PATH
ENV PATH="/usr/local/go/bin:/usr/lib/llvm-18/bin:$PATH"

# Working directory (mounted from host)
WORKDIR /tapio

# Default to bash shell
CMD ["/bin/bash"]
