FROM ubuntu:24.04

# Install eBPF toolchain and build tools
RUN apt-get update && apt-get install -y \
    # eBPF compilation
    clang-18 \
    llvm-18 \
    libbpf-dev \
    linux-headers-generic \
    # Build tools
    git \
    make \
    wget \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Go 1.25
ARG TARGETARCH
RUN wget -q https://go.dev/dl/go1.25.0.linux-${TARGETARCH:-amd64}.tar.gz && \
    tar -C /usr/local -xzf go1.25.0.linux-${TARGETARCH:-amd64}.tar.gz && \
    rm go1.25.0.linux-${TARGETARCH:-amd64}.tar.gz

# Install just
RUN curl --proto '=https' --tlsv1.2 -sSf https://just.systems/install.sh | bash -s -- --to /usr/local/bin

# Install golangci-lint (v2.x for Go 1.25 support)
RUN curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/master/install.sh | sh -s -- -b /usr/local/bin v2.7.1

# Add Go and LLVM to PATH
ENV PATH="/usr/local/go/bin:/usr/lib/llvm-18/bin:$PATH"

# Working directory (mounted from host)
WORKDIR /tapio

# Default to bash shell
CMD ["/bin/bash"]
