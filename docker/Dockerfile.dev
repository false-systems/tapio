FROM ubuntu:24.04

# Install eBPF toolchain + Go
RUN apt-get update && apt-get install -y \
    # eBPF compilation
    clang-18 \
    llvm-18 \
    libbpf-dev \
    linux-headers-generic \
    # Go toolchain
    golang-1.24 \
    # Build tools
    git \
    make \
    && rm -rf /var/lib/apt/lists/*

# Add Go to PATH
ENV PATH="/usr/lib/go-1.24/bin:$PATH"

# Working directory (mounted from host)
WORKDIR /tapio

# Default to bash shell
CMD ["/bin/bash"]
